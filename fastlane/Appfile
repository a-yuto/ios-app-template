# Apple ID / Team は環境ごとに上書きしてください
# .env (gitignore対象) に書くか、CI環境変数で渡すのを推奨

# app_identifier は project.pbxproj の PRODUCT_BUNDLE_IDENTIFIER から動的に解決する。
# ハードコードすると、リネーム後や Bundle ID 変更後にズレたまま残り、
# upload_to_testflight が存在しないアプリを探しに行って失敗する (niki-sandbox#97)。
def bundle_id_from_pbxproj
  path = Dir[File.join(__dir__, "..", "*.xcodeproj", "project.pbxproj")].first
  return nil unless path

  ids = File.read(path).scan(/PRODUCT_BUNDLE_IDENTIFIER = "?([^";]+)"?;/).flatten.uniq
  # Tests / UITests の Bundle ID を除いた、アプリ本体の ID を採用する
  ids.find { |id| !id.end_with?("Tests") }
end

app_identifier(ENV["APP_IDENTIFIER"] || bundle_id_from_pbxproj)
apple_id(ENV["FASTLANE_APPLE_ID"])
team_id(ENV["FASTLANE_TEAM_ID"]) if ENV["FASTLANE_TEAM_ID"]
